{
  "hooks": {
    "PreCompact": [
      {
        "matcher": "*",
        "_shannon": true,
        "hooks": [
          {
            "type": "command",
            "command": "transcript=$(jq -re '.transcript_path') && exec ~/.claude/save-session.sh \"$transcript\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "_shannon": true,
        "hooks": [
          {
            "type": "command",
            "command": "exec ~/.claude/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "_shannon": true,
        "hooks": [
          {
            "type": "command",
            "command": "exec ~/.claude/check-memory-synthesis.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "_shannon": true,
        "hooks": [
          {
            "type": "command",
            "command": "exec ~/.claude/check-tmp-path.sh"
          }
        ]
      }
    ]
  }
}
